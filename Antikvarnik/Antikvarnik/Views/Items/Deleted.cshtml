@model Item[]

@{
    ViewData["Title"] = "Скрити артикули";
}

<h1 class="text-center text-danger mb-4">Скрити артикули</h1>

@if (Model.Length == 0)
{
    
    <div class="alert alert-info text-center">Няма скрити артикули.</div>
}
else
{
    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-md-6 col-xl-4">
                <article class="card h-100 border-0 shadow-sm">
                    <img src="@item.MainPicUrl" class="card-img-top" alt="@item.Name" style="height: 240px; object-fit: cover;">
                    <div class="card-body d-flex flex-column">
                        <h2 class="h5">@item.Name</h2>
                        <p class="text-muted small mb-2">Категория: @(item.Category?.Name ?? "Без категория")</p>
                        <p class="mb-2"><strong>Статус:</strong> @item.Status</p>
                        <p class="card-text text-muted flex-grow-1">@item.Description</p>

                        <div class="d-flex flex-wrap gap-2 mt-3">
                            @* <a asp-controller="Items" asp-action="Details" asp-route-itemId="@item.Id" class="btn btn-warning">Детайли</a> *@

                 
                            <form asp-controller="Items" asp-action="Restore" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="itemId" value="@item.Id" />
                                <button type="submit" class="btn btn-success">Възстанови</button>
                            </form>
                        </div>
                    </div>
                </article>
            </div>
        }

    </div>
}