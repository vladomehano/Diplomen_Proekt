@model Item[]

@{
    ViewData["Title"] = "Чакащи одобрение";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
    <div>
        <h1 class="mb-1">Чакащи за одобрение артикули</h1>
        <p class="text-muted mb-0">Тук администраторът преглежда новите предложения и решава кои да публикува в каталога.</p>
    </div>
    <a asp-controller="Items" asp-action="Index" class="btn btn-outline-dark">Към каталога</a>
</div>

@if (TempData["StatusMessage"] is string message)
{
    <div class="alert alert-success">@message</div>
}

@if (Model.Length == 0)
{
    <div class="alert alert-info">В момента няма чакащи артикули за одобрение.</div>
}
else
{
    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-md-6 col-xl-4">
                <article class="card h-100 border-0 shadow-sm">
                    <img src="@item.MainPicUrl" class="card-img-top" alt="@item.Name" style="height: 250px; object-fit: cover;">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                            <h2 class="h5 mb-0">@item.Name</h2>
                            <span class="badge bg-info text-dark">@item.Status</span>
                        </div>

                        <p class="text-muted small mb-1">Категория: @(item.Category?.Name ?? "Без категория")</p>
                        <p class="text-muted small mb-1">Подаден от (username): @(item.Seller?.UserName ?? "Неизвестен потребител")</p>
                        <p class="text-muted small mb-2">Телефон: @(item.Seller?.PhoneNumber ?? "Няма посочен")</p>
                        <p class="mb-2"><strong>Цена:</strong> @item.Price.ToString("F2") лв.</p>
                        <p class="mb-2"><strong>Състояние:</strong> @item.Condition</p>
                        <p class="card-text text-muted flex-grow-1">@item.Description</p>

                        <div class="d-flex flex-wrap gap-2 mt-3">
                            <a asp-controller="Items" asp-action="Details" asp-route-itemId="@item.Id" class="btn btn-warning">Преглед</a>
                            <a asp-controller="Items" asp-action="Edit" asp-route-itemId="@item.Id" class="btn btn-outline-primary">Редакция</a>

                            <form asp-controller="Items" asp-action="Approve" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="itemId" value="@item.Id" />
                                <button type="submit" class="btn btn-success">Одобри</button>
                            </form>

                            <form asp-controller="Items" asp-action="Reject" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="itemId" value="@item.Id" />
                                <button type="submit" class="btn btn-outline-danger">Отхвърли</button>
                            </form>
                        </div>
                    </div>
                </article>
            </div>
        }
    </div>
}