@model ItemFormViewModel

@{
    ViewData["Title"] = "Добавяне на оферта";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <h1 class="text-center mb-3">Добави оферта към магазина</h1>
                <p class="text-center text-muted mb-4">
                    Всеки нов артикул, добавен от потребител, влиза със статус <strong>Waiting</strong> и чака одобрение от администратор.
                </p>

                <form asp-action="Add" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()

    
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Name" class="form-label">Име на артикул</label>
                            <input asp-for="Name" class="form-control" placeholder="Например: Старинен джобен часовник" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

  
                        <div class="col-md-6">
                            <label asp-for="CategoryId" class="form-label"></label>
                            <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select">
                                <option value="0">-- Избери категория --</option>
                            </select>
                            <span asp-validation-for="CategoryId" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Price" class="form-label">Предложена цена</label>
                            <input asp-for="Price" class="form-control" type="number" step="0.01" min="0" placeholder="0.00" />
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>

    
                        <div class="col-md-6">
                            <label asp-for="Condition" class="form-label">Състояние</label>
                            <input asp-for="Condition" class="form-control" placeholder="Отлично, много добро, реставрирано..." />
                            <span asp-validation-for="Condition" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="YearOrPeriod" class="form-label">Година или период</label>
                            <input asp-for="YearOrPeriod" class="form-control" placeholder="Напр. 1940-те години" />
                            <span asp-validation-for="YearOrPeriod" class="text-danger"></span>
                        </div>

   
                        <div class="col-12">
                            <label asp-for="Description" class="form-label">Описание</label>
                            <textarea asp-for="Description" class="form-control" rows="5" placeholder="Опиши произход, история, особености и състояние..."></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="MainPicFile" class="form-label"></label>
                            <input asp-for="MainPicFile" class="form-control" accept="image/*" />
                            <span asp-validation-for="MainPicFile" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="PicturesFiles" class="form-label">Галерия от снимки</label>
                            <input asp-for="PicturesFiles" class="form-control" accept="image/*" multiple />
                            <span asp-validation-for="PicturesFiles" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-center mt-4">
                        <button type="submit" class="btn btn-dark px-4">Изпрати офертата</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

}