@model Antikvarnik.Models.Item

@{
    ViewData["Title"] = "Add Item";
}

<h1 class="text-center">Добави артикул</h1>

<form asp-action="Add" method="post" enctype="multipart/form-data" class="mx-auto half-width">
    @Html.AntiForgeryToken()

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
    <div class="form-group">
        <label asp-for="Name">Име</label>
        <input asp-for="Name" class="form-control" placeholder="Name..." />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Price">Цена</label>
        <input asp-for="Price" class="form-control" type="number" step="0.01" placeholder="Цена..." />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Description">Описание</label>
        <textarea asp-for="Description" class="form-control" rows="4" placeholder="Описание..."></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <hr class="hr-2 bg-dark half-width mt-4" />

    <div class="form-group">
        <label for="MainPicFile">Главна снимка (upload from your PC)</label>
        <input type="file" class="form-control" id="MainPicFile" name="MainPicFile" accept="image/*" />
        <small class="form-text text-muted">Or provide a direct image URL below.</small>
    </div>

    <div class="form-group">
        <label asp-for="MainPicUrl">Главна снимка URL (незадължително)</label>
        <input asp-for="MainPicUrl" class="form-control" placeholder="https://..." />
        <span asp-validation-for="MainPicUrl" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label for="PicturesFiles">Галерия от снимки (Изберете снимките от вашия компютър)</label>
        <input type="file" class="form-control" id="PicturesFiles" name="PicturesFiles" accept="image/*" multiple />
        <small class="form-text text-muted">You can also paste additional image URLs below, separated by '|' (pipe).</small>
    </div>

    <div class="form-group">
        <label asp-for="PicturesUrls">Допълнителни снимки URLs (Разделени с |)</label>
        <input asp-for="PicturesUrls" class="form-control" placeholder="https://... | https://..." />
        <span asp-validation-for="PicturesUrls" class="text-danger"></span>
    </div>

    <hr class="hr-2 bg-dark half-width mt-4" />

    <div class="button-holder mt-2 d-flex justify-content-center">
        <button type="submit" class="btn chushka-bg-color">Create</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}