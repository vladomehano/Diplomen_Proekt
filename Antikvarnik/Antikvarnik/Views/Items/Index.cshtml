@using Antikvarnik.Models.Enums
@using Microsoft.AspNetCore.Mvc.Rendering
@model Item[]

@{
    ViewData["Title"] = "Каталог";
    var favoriteItemIds = (ViewBag.FavoriteItemIds as int[]) ?? Array.Empty<int>();
    var sortBy = (ViewBag.SortBy as string) ?? "newest";
}



<div class="page-hero d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
    <div>
        <h1 class="mb-1 text-success">Налични и публикувани антикварни предмети</h1>
        <p class="text-muted mb-0">Разгледай наличните артикули и подреди списъка по предпочитан критерий.</p>
    </div>

    <div class="d-flex align-items-center gap-2">
        <label for="sortBySelect" class="mb-0">Подреди по:</label>
<select id="sortBySelect" class="form-select catalog-sort-select">
    <option value="" selected="@(sortBy == "newest")">По подразбиране</option>
    <option value="price_asc" selected="@(sortBy == "price_asc")">Цена: ниска към висока</option>
    <option value="price_desc" selected="@(sortBy == "price_desc")">Цена: висока към ниска</option>
    <option value="oldest" selected="@(sortBy == "oldest")">Дата: стари към нови</option>
    <option value="newest" selected="@(sortBy == "newest")">Дата: нови към стари</option>
</select>
    </div>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <a asp-controller="Items" asp-action="Add" class="btn btn-outline-dark">Добави оферта</a>
    }
</div>
@if (TempData["StatusMessage"] is string message)
{
    <div class="alert alert-success">@message</div>
}




@if (Model.Length == 0)
{
    <div class="alert alert-info">Все още няма публикувани артикули.</div>
}
else
{
    <div class="row g-4">
        @foreach (Item item in Model)
        {
            var badgeClass = item.Status switch
            {
                ItemStatus.Available => "bg-success",
                
                ItemStatus.Sold => "bg-secondary",
                ItemStatus.Waiting => "bg-info text-dark",
                _ => "bg-danger"
            };

            <div class="col-md-6 col-xl-4">
                <article class="card h-100 shadow-sm border-0 surface-card">
                    <img src="@item.MainPicUrl" class="card-img-top" alt="@item.Name" style="height: 260px; object-fit: cover;">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                            <h3 class="h5 mb-0">@item.Name</h3>
                            <span class="badge @badgeClass">@item.Status</span>
                        </div>
               


                        <p class="text-muted small mb-2">Категория: @(item.Category?.Name ?? "Без категория")</p>
                        <p class="mb-2"><strong>Цена:</strong> @item.Price.ToString("F2") лв.</p>
                        <p class="mb-2"><strong>Състояние:</strong> @item.Condition</p>
                        @if (!string.IsNullOrWhiteSpace(item.YearOrPeriod))
                        {
                            <p class="mb-2"><strong>Период:</strong> @item.YearOrPeriod</p>
                        }

                        <p class="card-text text-muted flex-grow-1">@item.Description</p>

    
                        <div class="d-flex flex-wrap gap-2 mt-3">
                            <a asp-controller="Items" asp-action="Details" asp-route-itemId="@item.Id" class="btn btn-warning">Детайли</a>
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                var isFavorite = favoriteItemIds.Contains(item.Id);
                                <form asp-controller="Favorites" asp-action="Toggle" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="itemId" value="@item.Id" />
                                    <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                    <button type="submit" class="btn @(isFavorite ? "btn-danger" : "btn-outline-danger")">
                                        @(isFavorite ? "Премахни от любими" : "Добави в любими")
                                    </button>
                                </form>
                            }

                            @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
                            {
                                <a asp-controller="Items" asp-action="Edit" asp-route-itemId="@item.Id" class="btn btn-outline-primary">Редакция</a>
                            }
                            @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin") && item.Status == ItemStatus.Sold)
                            {
                                <form asp-controller="Items" asp-action="MarkAsAvailable" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="itemId" value="@item.Id" />
                                    <button type="submit" class="btn btn-outline-success">Върни като наличен</button>
                                </form>
                            }

                            @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
                            {
                                <form asp-controller="Items" asp-action="Delete" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="itemId" value="@item.Id" />
                                    <button type="submit" class="btn btn-outline-danger">Скрий</button>
                                </form>
                            }
                        </div>
                    </div>
                </article>
            </div>
        }

    </div>

    @section Scripts {
        <script>
            (function () {
                const sortSelect = document.getElementById('sortBySelect');
                if (!sortSelect) return;

                sortSelect.addEventListener('change', function () {
                    const url = new URL(window.location.href);
                    const selected = sortSelect.value;

                    if (!selected) {
                        url.searchParams.delete('sortBy');
                    } else {
                        url.searchParams.set('sortBy', selected);
                    }

                    window.location.href = url.toString();
                });
            })();
        </script>
    }
}