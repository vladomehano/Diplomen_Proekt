<!DOCTYPE html>
<html lang="bg">
<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Antikvarnik</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Antikvarnik.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        
            <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom box-shadow mb-4">
                <div class="container-fluid">
                    
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">Antikvarnik</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                
                <div id="mainNav" class="navbar-collapse collapse d-lg-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                       
                        <li class="nav-item">
                           
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">Начало</a>
                        </li>
                        <li class="nav-item">
                            
                            <a class="nav-link text-dark" asp-controller="Items" asp-action="Index">Каталог</a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Items" asp-action="Add">Добави оферта</a>
                                </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Reservations" asp-action="Mine">Моите резервации</a>
                            </li>
                        }
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Privacy">Контакти и как да закупя</a>
                        </li>

                        @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
                            {
                                    <li class="nav-item">
                                        <a class="nav-link text-dark" asp-controller="Items" asp-action="Deleted">Скрити артикули</a>
                                    </li>
    
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Items" asp-action="Waiting">Чакащи артикули</a>
                                </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Reservations" asp-action="Index">Резервации</a>
                            </li>
                            }
                       
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
            </nav>
    </header>

    <div class="container" style="min-height:83vh">
        
            <main role="main" class="pb-4">
                @RenderBody()
            </main>
    </div>

    <footer class="border-top footer text-muted">
            <div class="container py-2">
                &copy; 2026 - Antikvarnik
            </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>