@{
	ViewData["Title"] = "Начало";
}


<section class="py-5 text-center bg-light rounded-4 shadow-sm mb-5">
    <div class="px-4 py-4">
        <h1 class="display-5 fw-bold">Antikvarnik</h1>
        <p class="lead mx-auto" style="max-width: 760px;">
            Уеб платформа за публикуване, управление и продажба на редки предмети с колекционерска стойност.
            Потребителите могат да изпращат оферти към магазина, а администраторът да ги одобрява, публикува и управлява.
        </p>
        <div class="d-flex justify-content-center gap-3 flex-wrap">
            <a asp-controller="Items" asp-action="Index" class="btn btn-dark btn-lg">Разгледай каталога</a>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a asp-controller="Items" asp-action="Add" class="btn btn-outline-dark btn-lg">Добави оферта</a>
            }
        </div>
    </div>
</section>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-body">
                <h2 class="h4">Каталог с категории</h2>
                <p class="mb-0">Структуриране на артикулите по категории, статуси и визуална галерия за всеки предмет.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-body">
                <h2 class="h4">Потребителски оферти</h2>
                <p class="mb-0">Всеки регистриран потребител може да предложи артикул, който чака одобрение от администратор.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-body">
                <h2 class="h4">Администрация и контрол</h2>
                <p class="mb-0">Администраторът управлява видимостта на артикулите, одобрението на оферти и бъдещите клиентски отзиви.</p>
            </div>
        </div>
    </div>
</div>