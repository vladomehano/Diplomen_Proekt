@using Antikvarnik.Models.Enums
@model ReservationListItemViewModel[]

@{
    ViewData["Title"] = "Управление на резервации";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
    <div>
        <h1 class="mb-1">Резервации</h1>
        <p class="text-muted mb-0">Администраторът обработва заявките за покупка и маркира артикулите като продадени или свободни.</p>
    </div>
    <a asp-controller="Items" asp-action="Index" class="btn btn-outline-dark">Към каталога</a>
</div>

@if (TempData["StatusMessage"] is string message)
{
    <div class="alert alert-success">@message</div>
}

@if (Model.Length == 0)
{
    <div class="alert alert-info">Все още няма направени резервации.</div>
}
else
{
    <div class="row g-4">
        @foreach (var reservation in Model)
        {
            var badgeClass = reservation.ReservationStatus switch
            {
                ReservationStatus.Active => "bg-warning text-dark",
                ReservationStatus.Completed => "bg-success",
                _ => "bg-secondary"
            };

            <div class="col-md-6 col-xl-4">
                <article class="card h-100 shadow-sm border-0">
                    <img src="@reservation.ItemImageUrl" class="card-img-top" alt="@reservation.ItemName" style="height: 240px; object-fit: cover;">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                            <h2 class="h5 mb-0">@reservation.ItemName</h2>
                            <span class="badge @badgeClass">@reservation.ReservationStatus</span>
                        </div>

                        <p class="mb-2"><strong>Клиент:</strong> @reservation.UserEmail</p>
                        <p class="mb-2"><strong>Цена:</strong> @reservation.ItemPrice.ToString("F2") лв.</p>
                        <p class="mb-2"><strong>Статус на артикула:</strong> @reservation.ItemStatus</p>
                        <p class="mb-2"><strong>Заявено на:</strong> @reservation.ReservedOn.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</p>
                        @if (reservation.ProcessedOn.HasValue)
                        {
                            <p class="mb-2"><strong>Обработено на:</strong> @reservation.ProcessedOn.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</p>
                        }

                        <div class="d-flex flex-wrap gap-2 mt-3">
                            <a asp-controller="Items" asp-action="Details" asp-route-itemId="@reservation.ItemId" class="btn btn-warning">Детайли</a>

                            @if (reservation.ReservationStatus == ReservationStatus.Active)
                            {
                                <form asp-action="Complete" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="reservationId" value="@reservation.ReservationId" />
                                    <button type="submit" class="btn btn-success">Маркирай като продаден</button>
                                </form>

                                <form asp-action="Cancel" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="reservationId" value="@reservation.ReservationId" />
                                    <button type="submit" class="btn btn-outline-danger">Отмени резервация</button>
                                </form>
                            }
                        </div>
                    </div>
                </article>
            </div>
        }
    </div>
}